# Database
POSTGRES_PASSWORD=your_secure_postgres_password_here
DATABASE_URL=postgresql://poc_user:your_secure_postgres_password_here@localhost:5432/poc_db?schema=app

# Groq (fallback general LLM)
GROQ_API_KEY=your_groq_api_key_here

# Ollama Cloud — model-specific keys (Sprint A)
OLLAMA_BASE_URL=https://api.ollama.ai
OLLAMA_QWEN_KEY=your_ollama_qwen_key_here
OLLAMA_LLAMA_KEY=your_ollama_llama_key_here
OLLAMA_BIO_KEY=your_ollama_bio_key_here
OLLAMA_WHISPER_KEY=your_ollama_whisper_key_here

# Local Ollama (dev / docker)
OLLAMA_URL=http://localhost:11434

# Azure Cognitive Services TTS (Sprint B)
AZURE_TTS_KEY=your_azure_tts_key_here
AZURE_TTS_REGION=eastus

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=your_twilio_whatsapp_number_here
TWILIO_WEBHOOK_URL=https://your-tunnel-domain.trycloudflare.com/api/webhook/twilio
WHATSAPP_WEBHOOK_SECRET=your_whatsapp_webhook_secret_here

# Care Team Alerts
CARE_TEAM_WHATSAPP=+1234567890

# Cron job security (Sprint C)
CRON_SECRET=your_secure_random_secret_here
