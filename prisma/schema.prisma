generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id              String            @id @default(cuid())
  firstName       String
  lastName        String
  age             Int
  gender          String
  phone           String            @unique
  nextOfKinName   String?
  nextOfKinPhone  String?
  wakeTime        String?
  breakfastTime   String?
  lunchTime       String?
  dinnerTime      String?
  bedTime         String?
  consentGiven    Boolean           @default(false)
  createdAt       DateTime          @default(now())
  medicines       Medicine[]
  schedules       Schedule[]
  adherenceLogs   AdherenceLog[]
  conversationLogs ConversationLog[]
  escalations     Escalation[]

  @@map("patients")
}

model Medicine {
  id                String         @id @default(cuid())
  patientId         String
  patient           Patient        @relation(fields: [patientId], references: [id])
  medicineName      String
  dose              String
  frequency         String
  timingInstruction TimingInstruction
  durationDays      Int
  startDate         DateTime
  schedules         Schedule[]
  adherenceLogs     AdherenceLog[]

  @@map("medicines")
}

enum TimingInstruction {
  BEFORE_BREAKFAST
  AFTER_BREAKFAST
  WITH_LUNCH
  BEFORE_BED
  MORNING_EMPTY_STOMACH
}

model Schedule {
  id           String         @id @default(cuid())
  patientId    String
  patient      Patient        @relation(fields: [patientId], references: [id])
  medicineId   String
  medicine     Medicine       @relation(fields: [medicineId], references: [id])
  reminderTime DateTime
  date         DateTime       @db.Date
  status       ScheduleStatus @default(PENDING)

  @@map("schedules")
}

enum ScheduleStatus {
  PENDING
  SENT
  SKIPPED
}

model AdherenceLog {
  id             String           @id @default(cuid())
  patientId      String
  patient        Patient          @relation(fields: [patientId], references: [id])
  medicineId     String
  medicine       Medicine         @relation(fields: [medicineId], references: [id])
  logDate        DateTime         @db.Date
  scheduledTime  DateTime
  actualResponse ResponseType
  responseTime   DateTime?
  status         String?

  @@map("adherence_logs")
}

enum ResponseType {
  TAKEN
  SKIPPED
  NO_RESPONSE
  REMIND_LATER
}

model ConversationLog {
  id          String              @id @default(cuid())
  patientId   String
  patient     Patient             @relation(fields: [patientId], references: [id])
  messageIn   String
  messageOut  String?
  category    ConversationCategory
  escalated   Boolean             @default(false)
  createdAt   DateTime            @default(now())

  @@map("conversation_logs")
}

enum ConversationCategory {
  ADHERENCE
  SYMPTOM
  SOS
  GENERAL
}

model Escalation {
  id             String            @id @default(cuid())
  patientId      String
  patient        Patient           @relation(fields: [patientId], references: [id])
  trigger        EscalationTrigger
  patientMessage String
  aiResponse     String?
  alertSentAt    DateTime?
  outcome        String?

  @@map("escalations")
}

enum EscalationTrigger {
  SYMPTOM
  SOS
}
