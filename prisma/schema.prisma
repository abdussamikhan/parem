generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id                String            @id @default(cuid())
  firstName         String
  lastName          String
  age               Int
  gender            String
  phone             String            @unique
  mrn               String?           @unique
  nextOfKinName     String?
  nextOfKinPhone    String?
  wakeTime          String?
  breakfastTime     String?
  lunchTime         String?
  dinnerTime        String?
  bedTime           String?
  consentGiven      Boolean           @default(false)
  // Sprint A additions
  voicePreferred    Boolean           @default(false)
  familyGroupMode   Boolean           @default(false)
  whatsappGroupId   String?
  conditionCategory String?
  createdAt         DateTime          @default(now())
  medicines         Medicine[]
  schedules         Schedule[]
  adherenceLogs     AdherenceLog[]
  conversationLogs  ConversationLog[]
  escalations       Escalation[]
  familyMembers     FamilyMember[]
  appointments      Appointment[]
  riskScores        RiskScore[]

  @@map("patients")
}

model Medicine {
  id                String            @id @default(cuid())
  patientId         String
  patient           Patient           @relation(fields: [patientId], references: [id])
  medicineName      String
  dose              String
  frequency         String
  timingInstruction TimingInstruction
  durationDays      Int
  startDate         DateTime
  schedules         Schedule[]
  adherenceLogs     AdherenceLog[]

  @@map("medicines")
}

enum TimingInstruction {
  UPON_WAKING
  MORNING_EMPTY_STOMACH
  BEFORE_BREAKFAST
  AFTER_BREAKFAST
  WITH_LUNCH
  BEFORE_LUNCH
  AFTER_LUNCH
  BEFORE_DINNER
  AFTER_DINNER
  BEFORE_BED
}

model Schedule {
  id           String         @id @default(cuid())
  patientId    String
  patient      Patient        @relation(fields: [patientId], references: [id])
  medicineId   String
  medicine     Medicine       @relation(fields: [medicineId], references: [id])
  reminderTime DateTime
  date         DateTime       @db.Date
  status       ScheduleStatus @default(PENDING)

  @@map("schedules")
}

enum ScheduleStatus {
  PENDING
  SENT
  SKIPPED
  TAKEN
  MISSED
}

model AdherenceLog {
  id             String       @id @default(cuid())
  patientId      String
  patient        Patient      @relation(fields: [patientId], references: [id])
  medicineId     String
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
  logDate        DateTime     @db.Date
  scheduledTime  DateTime
  actualResponse ResponseType
  responseTime   DateTime?
  status         String?

  @@map("adherence_logs")
}

enum ResponseType {
  TAKEN
  SKIPPED
  NO_RESPONSE
  REMIND_LATER
}

model ConversationLog {
  id          String               @id @default(cuid())
  patientId   String
  patient     Patient              @relation(fields: [patientId], references: [id])
  messageIn   String
  messageOut  String?
  category    ConversationCategory
  escalated   Boolean              @default(false)
  createdAt   DateTime             @default(now())

  @@map("conversation_logs")
}

enum ConversationCategory {
  ADHERENCE
  SYMPTOM
  SOS
  GENERAL
}

model Escalation {
  id             String            @id @default(cuid())
  patientId      String
  patient        Patient           @relation(fields: [patientId], references: [id])
  trigger        EscalationTrigger
  patientMessage String
  aiResponse     String?
  alertSentAt    DateTime?
  outcome        String?
  createdAt      DateTime          @default(now())

  @@map("escalations")
}

enum EscalationTrigger {
  SYMPTOM
  SOS
}

// ─── Sprint A: New Models ─────────────────────────────────────────────────────

model FamilyMember {
  id           String   @id @default(cuid())
  patientId    String
  patient      Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  relationship String?
  consentGiven Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@map("family_members")
}

model Appointment {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  title       String
  scheduledAt DateTime
  attended    Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  @@map("appointments")
}

model RiskScore {
  id           String    @id @default(cuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id], onDelete: Cascade)
  calculatedAt DateTime  @default(now())
  score        RiskLevel
  rawFeatures  Json?
  rationale    String?

  @@map("risk_scores")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

// ─── Auth: Staff Users ────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PHYSICIAN
  NURSE
  COORDINATOR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         UserRole
  createdAt    DateTime @default(now())

  @@map("users")
}
